# Root — OS, secrets, editors, and rules that apply anywhere in the repo.
# Backend-specific: backend/.gitignore
# Frontend-specific: frontend/.gitignore

# Python bytecode (any path, e.g. scripts/ or tools/)
__pycache__/
*.py[cod]
*$py.class

# Environment & secrets
.env
.env.*
!.env.example

# Editors & OS
.DS_Store
.idea/
*.swp
*.swo

# Cursor
.cursorignore
.cursorindexingignore

# Logs (repo root)
*.log

# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example

# Jupyter (if used at repo root)
.ipynb_checkpoints

# Sphinx / static site at repo root
/site
docs/_build/

# Abstra
.abstra/

# Agent skills (sources pinned in skills-lock.json; sync separately)
.agents/skills/

# PyPI config (sometimes at home dir symlink; ignore if present in repo)
.pypirc
hsm-dashboard-firebase-adminsdk-4z1mo-31df335459.json
