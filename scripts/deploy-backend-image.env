GCP_PROJECT_ID="hsm-dashboard"
ARTIFACT_REGION="us-central1"
ARTIFACT_REPOSITORY="hsm-app"
IMAGE_NAME="backend"

# Cloud Run target platform (default is safest for Cloud Run).
BUILD_PLATFORM="linux/amd64"

# Optional override. If unset, script uses `<git-sha-12>-<platform-arch>`
# (for example: `abc123def456-amd64`).
# IMAGE_TAG="manual-tag"
