rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Starter template: open read/write until the date below. Replace with
      // production rules before relying on this in a public app.
      allow read, write: if request.time < timestamp.date(2027, 12, 31);
    }
  }
}
